# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BBFrontendStarter

# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the API (defaults to /api for internal Next.js routes)
NEXT_PUBLIC_API_URL=/api

# ─── Auth ─────────────────────────────────────────────────────────────────────
# CHANGE THIS to a long random secret in production!
# Generate one: openssl rand -base64 32
JWT_SECRET=change-me-in-production-use-a-long-random-secret

# ─── Database (replace with your real DB when you're ready) ──────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/nexstarter

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
